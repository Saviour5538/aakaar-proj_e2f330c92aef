# Database connection string
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>

# Secret key for JWT authentication
JWT_SECRET=<random secret>

# Backend port
PORT=8000

# Frontend API URL for development
VITE_API_URL=http://localhost:8000

# PostgreSQL environment variables for pgvector service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<postgres password>
POSTGRES_DB=tictactoe

# OpenAI API key for AI-related features (if applicable)
OPENAI_API_KEY=<your_openai_api_key>

# Anthropic API key for AI-related features (if applicable)
ANTHROPIC_API_KEY=<your_anthropic_api_key>

# Pinecone API key for vector database (if applicable)
PINECONE_API_KEY=<your_pinecone_api_key>

# PostgreSQL URL for pgvector service (if applicable)
POSTGRES_URL=postgresql://postgres:<postgres password>@pgvector:5432/tictactoe